{
  "manifest_version": 3,
  "name": "TinyKittens Chat Timeline Markers",
  "version": "0.1.0",
  "description": "Overlays clickable markers on the TinyKittens live stream progress bar, parsed from moderator-posted chat timestamps.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/live_chat*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["storage-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/live_chat*"],
      "js": ["storage-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TinyKittens Chat Timeline Markers"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
